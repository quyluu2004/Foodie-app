# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017/foodie

# JWT Secret Key — PHẢI tạo bằng: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_GENERATED_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_GENERATED_SECRET

# Port server
PORT=8080

# Node Environment (development | production)
NODE_ENV=development

# Cloudinary Configuration (optional - for image upload)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google Gemini AI Key
GEMINI_API_KEY=your_gemini_api_key_here

# Unsplash API
UNSPLASH_ACCESS_KEY=your_unsplash_key_here

# Allowed Origins (for Production)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
